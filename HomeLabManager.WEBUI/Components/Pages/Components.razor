@page "/components"
@using System.Net.Http.Json
@using HomeLabManager.WEBUI.Models
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Components</PageTitle>

<div class="container py-4">
	<h1>Component Library</h1>
	<p class="text-muted">Manage hardware components that can be installed in devices.</p>

	@if (errorMessage != null)
	{
		<div class="alert alert-danger">@errorMessage</div>
	}

	@if(components == null)
	{
		<p><em>Loading components...</em></p>
	}
	else if (!components.Any())
	{
		<div class="alert alert-info">
			<p>No components found. Use the "Add Component" button to create new components for your devices.</p>
		</div>
        <button type="button" class="btn btn-primary" @onclick="NavigateToAddComponent">New Component</button>
	}
	else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <p class="mb-0">Showing @components.Count component(s)</p>
            </div>
            <a href="/components/add" class="btn btn-primary">
                <span>+ New Component</span>
            </a>
        </div>
        <div class="row g-3">
            @foreach (var component in components)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@component.Name</h5>
                            <dl class="row mb-0">
                                @if (!string.IsNullOrEmpty(component.ComponentType))
                                {
                                    <dt class="col-sm-4">Type:</dt>
                                    <dd class="col-sm-8">@component.ComponentType</dd>
                                }
                                @if (!string.IsNullOrEmpty(component.Manufacturer))
                                {
                                    <dt class="col-sm-4">Manufacturer:</dt>
                                    <dd class="col-sm-8">@component.Manufacturer</dd>
                                }
                                @if (!string.IsNullOrEmpty(component.ModelNumber))
                                {
                                    <dt class="col-sm-4">Model:</dt>
                                    <dd class="col-sm-8">@component.ModelNumber</dd>
                                }
                                @if (!string.IsNullOrEmpty(component.Specifications))
                                {
                                    <dt class="col-sm-4">Specs:</dt>
                                    <dd class="col-sm-8">@component.Specifications</dd>
                                }
                                @if (component.UnitPrice.HasValue)
                                {
                                    <dt class="col-sm-4">Price:</dt>
                                    <dd class="col-sm-8">@component.UnitPrice.Value.ToString("C")</dd>
                                }
                            </dl>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <button 
                                class="d-flex gap-2 btn btn-sm btn-outline-danger" 
                                @onclick="() => ConfirmDelete(component)">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
            @if (componentToDelete != null)
            {
                <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to delete <strong>@componentToDelete.Name</strong>?</p>
                                <p class="text-muted mb-0">This action cannot be undone.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                                    @if (isDeleting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Deleting...</span>
                                    }
                                    else
                                    {
                                        <span>Delete</span>
                                    }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            }
        </div>
	}

</div>



@code{
    private List<Component>? components;
    private string? errorMessage;
    private bool isDeleting;
    private Component? componentToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadComponentsAsync();
    }
    private async Task LoadComponentsAsync()
    {
        try
        {
            // https://learn.microsoft.com/en-us/dotnet/api/system.net.http.ihttpclientfactory.createclient?view=net-10.0-pp#remarks
            // HttpClientFactory will automatically handle DNS changes and connection pooling, so we can create a new client instance for each request
            var client = HttpClientFactory.CreateClient("HomeLabApi");

            // Attempt to load components from the API
            components = await client.GetFromJsonAsync<List<Component>>("api/components");
            errorMessage = null; // Clear any previous error message on successful load

        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading components: {ex.Message}";
        }
    }


    private void NavigateToAddComponent()
    {
        NavigationManager?.NavigateTo("/components/add");
    }

    private void ConfirmDelete(Component component)
    {
        componentToDelete = component;
    }

    // to stop deleting if the user changes their mind after clicking delete
    private void CancelDelete()
    {
		componentToDelete = null;
    }
    private async Task HandleDelete()
    {
        if (componentToDelete == null) return;

        isDeleting = true;
        try
        {
            // Create a new HttpClient instance for the delete request
            var client = HttpClientFactory.CreateClient("HomeLabApi");

			// Send a DELETE request to the API to delete the component
            var response = await client.DeleteAsync($"api/components/{componentToDelete.Id}");

            if (response.IsSuccessStatusCode)
            {
                // Remove from list and close modal
                components?.Remove(componentToDelete);
                componentToDelete = null;
                errorMessage = null;
            }
            else
            {
                errorMessage = $"Failed to delete component: {response.ReasonPhrase}";
                componentToDelete = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting component: {ex.Message}";
            componentToDelete = null;
        }
        finally
        {
            isDeleting = false;
        }
    }
}