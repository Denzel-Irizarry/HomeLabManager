@page "/register-image"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@inject IHttpClientFactory HttpClientFactory
@*this gives a JS capabilties to blazor*@
@inject IJSRuntime JS
@inject NavigationManager NavigationManager


<PageTitle>Register By Image</PageTitle>

<div class="container py-4">
	<h1>Register by Image</h1>
	<p class="text-muted">Upload a barcode or QR image to register a device.</p>

	<div id="dropZone" class="border border-2 rounded p-4 text-center mb-3">
		Drag & drop an image here or select browse file
		<button type="button" class="btn btn-link p-0" @onclick="OpenFilePicker">browse</button> 
	</div>
	<InputFile id="hiddenFileInput" OnChange="HandleFileSelected" class="d-none" accept="image/*"/>

	@if(!string.IsNullOrWhiteSpace(selectedFileName)){
		// if a file is selected, show the file name and a button to clear the selection
		<div class="d-flex align-items-center gap-2 mt-2">
			<p class="mb-0"><button type="button" class="btn btn-sm btn-outline-danger" title="Remove file" @onclick="ClearSelectedFile">X</button> Selected: @selectedFileName</p>

		</div>
	}

	<button type="button" 
			class="btn btn-primary mt-3" 
			@onclick="UploadAndRegisterAsync"
			disabled="@(selectedFile is null)">
		Upload Image & Register
	</button>

	@*
	This will be if there is a status message to show after attempting to upload and register the device. 
	It will display the message in green for success or red for error based on the value of uploadisError.
	*@
	@if (!string.IsNullOrWhiteSpace(uploadStatusMessage))
	{
		<div class="mt-3">
			<p class="@(uploadisError ? "text-danger" : "text-success")">@uploadStatusMessage</p>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(uploadStatusMessage))
	{
		<div class="mt-2">
			<button type="button"
					class="btn btn-sm btn-outline-secondary" 
					@onclick='() => NavigationManager.NavigateTo("/devices")'>
				View Devices
			</button>
		</div>
	}


</div>




@code {
	/*
	 * allows for storing the selected file & its name when a user uploads an image. This is for processing the file later
	 * https://learn.microsoft.com/en-us/dotnet/api/microsoft.aspnetcore.components.forms.ibrowserfile?view=aspnetcore-9.0
	 */
	private IBrowserFile? selectedFile;
	private string? selectedFileName;

	//these are for showing the status of the upload process, such as success or error messages, 
	// to provide feedback to the user after they attempt to upload an image.
	private string? uploadStatusMessage;
	private bool uploadisError;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			// this calls the JS function to set up the drag and drop functionality on the drop zone element
			await JS.InvokeVoidAsync("registerImageDropZone", "dropZone", "hiddenFileInput");
		}
	}

	private void HandleFileSelected(InputFileChangeEventArgs eFile)
	{
		selectedFile = eFile.File;
		selectedFileName = selectedFile?.Name;

	}
	private async Task OpenFilePicker()
	{
		// this calls the JS function to trigger a click on the hidden file input, allowing the user to select a file
		await JS.InvokeVoidAsync("triggerFileInputClick", "hiddenFileInput");
	}

	// this method clears the selected file and resets the file input, allowing the user to choose a different file if needed
	private async Task ClearSelectedFile()
	{
		selectedFile = null;
		selectedFileName = null;
		await JS.InvokeVoidAsync("clearFileInput", "hiddenFileInput");
	}

	private async Task UploadAndRegisterAsync()
	{
		if(selectedFile is null)
		{
			uploadisError = true;
			uploadStatusMessage = "No file selected. Please select an image to upload.";
			//breaks out of the method early if there is no file selected, preventing further processing 
			return;
		}

		try
		{
			// creates an HttpClient instance, which is configured to talk to HomeLabApi. client will then send the selected file to the server for processing.
			var client = HttpClientFactory.CreateClient("HomeLabApi");

			// creates a MultipartFormDataContent object, which is used to send the selected file as part of an HTTP request to the server.
			using var content = new MultipartFormDataContent();

			// limit to 10 MB
			using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); 

			// creates a StreamContent from the selected file's stream, which can be sent in an HTTP request to the server for processing.
			using var streamContent = new StreamContent(stream);

			/*adds the stream content to the multipart form data content with the name "file" and the original file name, 
			 * which will be used by the server to identify and process the uploaded file.
			 * https://learn.microsoft.com/en-us/dotnet/api/system.net.http.headers.mediatypeheadervalue?view=net-9.0
			 * https://learn.microsoft.com/en-us/dotnet/api/system.net.http.headers.httprequestheaders?view=net-9.0
			 */
			streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);

			/*
			 * streamContent is the StreamContent instance containing the file data.
			 * file is the form field name (e.g., "file").
			 * selectedFile.Name is the filename to be sent in the header
			 */
			content.Add(streamContent, "file", selectedFile.Name);

			// sends a POST request to the server at the specified endpoint ("/api/devices/register") with the multipart form data content containing 
			// the uploaded file. The server will then process the file and attempt to register the device based on the information extracted from the image.
			var response = await client.PostAsync("/api/devices/register", content);

			if (response.IsSuccessStatusCode)
			{
				// If the server responds with a success status code, it indicates that the image was uploaded and the device was registered successfully. The UI will then display a success message to the user.
				uploadisError = false;
				uploadStatusMessage = "Image uploaded and device registered successfully!";

				// Clear the selected file after successful upload and registration
				await ClearSelectedFile(); 
			}
			else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
			{
				// If the server responds with a 409 Conflict status code, it indicates that a device with the same identifier already exists in the system. The UI will then display an error message to the user, informing them of the conflict and suggesting that they check the image and try again.
				uploadisError = true;
				uploadStatusMessage = "A device with the same identifier already exists. Please check the image and try again.";
			}
			else if(response.StatusCode == System.Net.HttpStatusCode.BadRequest)
			{
				// If the server responds with a 400 Bad Request status code, it indicates that there was an issue with the uploaded image, such as it being unreadable or not containing valid information for device registration.
				uploadisError = true;
				uploadStatusMessage = "The uploaded image is invalid or unreadable. Please check the image and try again.";
			}
			else
			{
				// If the server responds with an error status code, it indicates that there was a problem with the upload or registration process.
				// The UI will then display an error message to the user, including the status code returned by the server for troubleshooting purposes.
				uploadisError = true;
				var error = await response.Content.ReadAsStringAsync();
				uploadStatusMessage = $"Failed to register: {(int)response.StatusCode} - {error}";
			}

		}
		catch (OperationCanceledException)
		{
			uploadisError = true;
			uploadStatusMessage = "The upload was canceled. Please try again.";
		}
		catch (IOException ex)
		{
			uploadisError = true;
			uploadStatusMessage = $"An error occurred while reading the file: {ex.Message}";
		}
		catch (Exception ex)
		{
			uploadisError = true;
			uploadStatusMessage = $"An error occurred while uploading the image: {ex.Message}";
		}


	}


}

<script src="/registerImage.js"></script>
