@page "/register-image"
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using HomeLabManager.WEBUI.Models
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Register By Image</PageTitle>

<div class="container py-4">
    <h1>Register by Image</h1>
    <p class="text-muted">Upload a barcode or QR image to register a device.</p>

    <div class="card mb-4 register-image-lookup">
        <div class="card-body">
            <h2 class="h5">Lookup by Serial / Service Tag</h2>
            <p class="text-muted mb-3">Use this to test vendor lookup directly (for example, Dell service tags).</p>

            <div class="row g-2 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">Serial or Service Tag</label>
                    <InputText class="form-control" @bind-Value="serialLookupQuery" placeholder="e.g. 5D34GT2" />
                </div>
                <div class="col-md-4">
                    <button type="button" class="btn btn-outline-primary w-100" disabled="@isSerialLookupInProgress" @onclick="HandleSerialLookupAsync">
                        @if (isSerialLookupInProgress)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Looking up...</span>
                        }
                        else
                        {
                            <span>Lookup Tag</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>

    <EditForm Model="formModel" OnSubmit="HandleSubmit">
        <div class="mb-3">
            <InputFile @key="fileInputKey" class="form-control" OnChange="HandleFileSelected" accept="image/*" />
        </div>

        @if (selectedFile != null)
        {
            <div class="d-flex align-items-center gap-2 mt-2 mb-3">
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearSelection" title="Remove file">X</button>
                <span>Selected: @selectedFile.Name</span>
            </div>
        }

        <button type="submit" class="btn btn-primary" disabled="@(selectedFile == null || isUploading)">
            @if (isUploading)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span> Uploading...</span>
            }
            else
            {
                <span>Upload Image & Register</span>
            }
        </button>
    </EditForm>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mt-3">
            <p class="@(isError ? "text-danger" : "text-success") mb-0">@statusMessage</p>
        </div>
    }

    @if (previewResult != null)
    {
        <div class="card mt-4">
            <div class="card-body">
                <h3 class="card-title h5">Preview Result</h3>

                <div class="mb-3">
                    <p class="mb-1"><strong>Extracted Code:</strong> @previewResult.ExtractedCode</p>
                    <p class="mb-1"><strong>Code Type:</strong> @previewResult.ExtractedCodeType</p>
                    <p class="mb-1"><strong>Detected Vendor:</strong> @(string.IsNullOrWhiteSpace(previewResult.DetectedVendor) ? "Unknown" : previewResult.DetectedVendor)</p>
                    <p class="mb-1"><strong>Lookup Attempted:</strong> @(previewResult.CanAttemptLookup ? "Yes" : "No")</p>
                    <p class="mb-1"><strong>Lookup Status:</strong> @ReadableLookupStatus(previewResult.LookupStatus)</p>
                    <p class="mb-0"><strong>Message:</strong> @previewResult.Message</p>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Serial Number</label>
                        <InputText class="form-control" @bind-Value="reviewModel.SerialNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Vendor Name</label>
                        <InputText class="form-control" @bind-Value="reviewModel.VendorName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Product Name</label>
                        <InputText class="form-control" @bind-Value="reviewModel.ProductName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Model Number</label>
                        <InputText class="form-control" @bind-Value="reviewModel.ModelNumber" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Nick Name</label>
                        <InputText class="form-control" @bind-Value="reviewModel.NickName" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Location</label>
                        <InputText class="form-control" @bind-Value="reviewModel.Location" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">UPC</label>
                        <InputText class="form-control" @bind-Value="reviewModel.UPC" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <InputText class="form-control" @bind-Value="reviewModel.Category" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <InputTextArea class="form-control" @bind-Value="reviewModel.Description" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(previewResult.SourceUrl))
                    {
                        <div class="col-12">
                            <a class="btn btn-sm btn-outline-secondary" href="@previewResult.SourceUrl" target="_blank">
                                View Source
                            </a>
                        </div>
                    }

                    @if (ShouldShowManualLookupLink(previewResult))
                    {
                        <div class="col-12">
                            <a class="btn btn-sm btn-outline-warning" href="@previewResult.SupportLookupUrl" target="_blank">
                                @GetManualLookupButtonText(previewResult)
                            </a>
                        </div>
                    }

                    <div class="col-12 d-flex gap-2">
                        <button type="button" class="btn btn-success" @onclick="SaveDeviceAsync">Add Device</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ClearSelection">Clear</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (showDevicesLink)
    {
        <div class="mt-2">
            <a class="btn btn-sm btn-outline-secondary" href="/devices">View Devices</a>
        </div>
    }
</div>

@code {
    
    private class UploadModel { }
    private UploadModel formModel = new();
    // This model is used to display the preview result and any extracted information from the image
    private class ReviewModel
    {
        public string SerialNumber { get; set; } = string.Empty;
        public string NickName { get; set; } = string.Empty;
        public string Location { get; set; } = string.Empty;
        public string VendorName { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string ModelNumber { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string UPC { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
    }

    private IBrowserFile? selectedFile;
    private bool isUploading;
    private string statusMessage = "";
    private bool isError;
    private bool showDevicesLink;
    private int fileInputKey;
    private bool isSerialLookupInProgress;
    private string serialLookupQuery = string.Empty;
    private UiPreferences preferences = new();
    
    //private string? extractedCode;
    private ImageScrapePreviewResponse? previewResult;
    private ReviewModel reviewModel = new();

    // Handle file selection and reset state
    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        statusMessage = "";
        showDevicesLink = false;
        isError = false;
        previewResult = null;
        reviewModel = new ReviewModel();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadPreferencesAsync();
    }

    private async Task HandleSerialLookupAsync()
    {
        if (string.IsNullOrWhiteSpace(serialLookupQuery))
        {
            statusMessage = "Enter a serial number or service tag before lookup.";
            isError = true;
            return;
        }

        isSerialLookupInProgress = true;
        statusMessage = "";
        isError = false;
        showDevicesLink = false;

        try
        {
            using var client = HttpClientFactory.CreateClient("HomeLabApi");

            var response = await client.PostAsJsonAsync("api/scraper/search", new ScraperSearchRequest
            {
                Query = serialLookupQuery.Trim()
            });

            if (!response.IsSuccessStatusCode)
            {
                var failedResponse = await response.Content.ReadAsStringAsync();
                statusMessage = $"Lookup failed: {(int)response.StatusCode} - {failedResponse}";
                isError = true;
                return;
            }

            var lookupResult = await response.Content.ReadFromJsonAsync<ScrapeResult>();
            if (lookupResult == null)
            {
                statusMessage = "Lookup returned an empty response.";
                isError = true;
                return;
            }

            previewResult = new ImageScrapePreviewResponse
            {
                ExtractedCode = serialLookupQuery.Trim(),
                ExtractedCodeType = "SerialNumber",
                CanAttemptLookup = true,
                LookupSucceeded = lookupResult.Success,
                Message = lookupResult.Message,
                DetectedVendor = lookupResult.DetectedVendor,
                LookupStatus = lookupResult.LookupStatus,
                SupportLookupUrl = lookupResult.SuggestedLookupUrl,
                ProductName = lookupResult.DeviceInfo?.ProductName ?? string.Empty,
                Manufacturer = lookupResult.DeviceInfo?.Manufacturer ?? string.Empty,
                ModelNumber = lookupResult.DeviceInfo?.ModelNumber ?? string.Empty,
                UPC = lookupResult.DeviceInfo?.UPC ?? string.Empty,
                Category = lookupResult.DeviceInfo?.Category ?? string.Empty,
                Description = lookupResult.DeviceInfo?.Description ?? string.Empty,
                ImageUrl = lookupResult.DeviceInfo?.ImageUrl ?? string.Empty,
                SourceUrl = lookupResult.DeviceInfo?.SourceUrl ?? lookupResult.SuggestedLookupUrl ?? string.Empty
            };

            PopulateReviewModelFromPreview();
            statusMessage = lookupResult.Success
                ? "Lookup completed successfully. Review values before saving."
                : lookupResult.LookupStatus == "blocked" || lookupResult.LookupStatus == "manual_lookup_required"
                    ? "Automated lookup could not get a specific product. Use the vendor support link below to continue manually."
                    : "Lookup completed but did not return device information.";
            isError = !lookupResult.Success;
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred while looking up the serial number: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSerialLookupInProgress = false;
        }
    }

    // Clear the selected file and reset state
    private void ClearSelection()
    {
        ResetFormState(clearStatusMessage: true);
    }

    private void ResetFormState(bool clearStatusMessage)
    {
        selectedFile = null;
        if (clearStatusMessage)
        {
            statusMessage = "";
        }
        showDevicesLink = false;
        isError = false;
        previewResult = null;
        reviewModel = new ReviewModel();
        fileInputKey++;
    }

    //this method is called when the user submits the form to upload the image and generate a preview. It handles the file upload, calls the API, and processes the response to display the preview information.
    private async Task HandleSubmit()
    {
        if (selectedFile == null) return;

        isUploading = true;
        statusMessage = "";


        try
        {
            // starting upload
            using var client = HttpClientFactory.CreateClient("HomeLabApi");
            using var content = new MultipartFormDataContent();

            // Allow larger files, e.g., 20MB max
            long maxFileSize = 10485760 * 2;


            using var sourceStream = selectedFile.OpenReadStream(maxFileSize);
            var fileContent = new StreamContent(sourceStream);

            // Protect against empty or invalid content types crashing the headers
            var contentType = string.IsNullOrWhiteSpace(selectedFile.ContentType)
                ? "application/octet-stream"
                : selectedFile.ContentType;

            if (MediaTypeHeaderValue.TryParse(contentType, out var parsedHeader))
            {
                fileContent.Headers.ContentType = parsedHeader;
            }
            else
            {
                fileContent.Headers.ContentType = new MediaTypeHeaderValue("application/octet-stream");
            }

            content.Add(fileContent, "file", selectedFile.Name);

            // sending POST

            using var cts = new CancellationTokenSource(TimeSpan.FromMinutes(2));
            HttpResponseMessage response;
            try
            {
                response = await client.PostAsync("api/scraper/from-image", content, cts.Token);
            }
            catch (OperationCanceledException ex)
            {
                // cancelled/timeout
                throw new Exception("The upload timed out. Please try again with a smaller image or check your connection.", ex);
            }

            if (response.IsSuccessStatusCode)
            {
                previewResult = await response.Content.ReadFromJsonAsync<ImageScrapePreviewResponse>(cancellationToken: cts.Token);
                if (previewResult != null)
                {
                    PopulateReviewModelFromPreview();
                    statusMessage = "Image scanned successfully.";
                    isError = false;
                    showDevicesLink = false;
                }
                else
                {
                    statusMessage = "The preview response was empty.";
                    isError = true;
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                var responseText = await response.Content.ReadAsStringAsync();
                statusMessage = "A preview conflict occurred while processing the image.";
                isError = true;
                showDevicesLink = false;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var responseText = await response.Content.ReadAsStringAsync();
                statusMessage = !string.IsNullOrWhiteSpace(responseText) 
                    ? responseText 
                    : "The image could not be scanned or a preview could not be created.";
                isError = true;
                showDevicesLink = false;
            }
            else
            {
                var responseText = await response.Content.ReadAsStringAsync();
                statusMessage = $"Failed to generate preview: {(int)response.StatusCode} - {responseText}";
                isError = true;
                showDevicesLink = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred while generating the image preview: {ex.Message}";
            isError = true;
            showDevicesLink = false;
        }
        finally
        {
            isUploading = false;
        }
    }

    // This method would be called when the user confirms the preview information and wants to save the device to their inventory.
    private async Task SaveDeviceAsync()
    {
        try
        {
            using var client = HttpClientFactory.CreateClient("HomeLabApi");

            var request = new ManualDeviceRegisterRequest
            {
                SerialNumber = string.IsNullOrWhiteSpace(reviewModel.SerialNumber) ? null : reviewModel.SerialNumber,
                NickName = string.IsNullOrWhiteSpace(reviewModel.NickName) ? null : reviewModel.NickName,
                Location = string.IsNullOrWhiteSpace(reviewModel.Location) ? null : reviewModel.Location,
                VendorName = string.IsNullOrWhiteSpace(reviewModel.VendorName) ? null : reviewModel.VendorName,
                ProductName = string.IsNullOrWhiteSpace(reviewModel.ProductName) ? null : reviewModel.ProductName,
                ModelNumber = string.IsNullOrWhiteSpace(reviewModel.ModelNumber) ? null : reviewModel.ModelNumber
            };

            var response = await client.PostAsJsonAsync("api/devices/manual", request);
            var responseText = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Device added successfully.";
                isError = false;
                showDevicesLink = true;

                if (preferences.ClearRegisterImageAfterSave)
                {
                    ResetFormState(clearStatusMessage: false);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                statusMessage = !string.IsNullOrWhiteSpace(responseText)
                    ? responseText
                    : "A device with the same serial number already exists.";
                isError = true;
                showDevicesLink = false;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                statusMessage = !string.IsNullOrWhiteSpace(responseText)
                    ? responseText
                    : "The reviewed device information could not be saved.";
                isError = true;
                showDevicesLink = false;
            }
            else
            {
                statusMessage = $"Failed to save device: {(int)response.StatusCode} - {responseText}";
                isError = true;
                showDevicesLink = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred while saving the device: {ex.Message}";
            isError = true;
            showDevicesLink = false;
        }
    }

    private void PopulateReviewModelFromPreview()
    {
        if (previewResult == null)
        {
            reviewModel = new ReviewModel();
            return;
        }

        reviewModel = new ReviewModel
        {
            SerialNumber = previewResult.ExtractedCodeType == "SerialNumber"
                ? previewResult.ExtractedCode
                : string.Empty,
            VendorName = !string.IsNullOrWhiteSpace(previewResult.Manufacturer)
                ? previewResult.Manufacturer
                : previewResult.DetectedVendor,
            ProductName = previewResult.ProductName,
            ModelNumber = previewResult.ModelNumber,
            Description = previewResult.Description,
            UPC = previewResult.UPC,
            Category = previewResult.Category
        };
    }

    private static bool ShouldShowManualLookupLink(ImageScrapePreviewResponse result)
    {
        // Show manual lookup link when automatic lookup fails or is blocked
        if (string.IsNullOrWhiteSpace(result.SupportLookupUrl) || string.IsNullOrWhiteSpace(result.DetectedVendor))
        {
            return false;
        }

        var failureStatuses = new[] 
        { 
            "blocked",           // Vendor actively blocked the request
            "manual_lookup_required", // Vendor returned a generic support page
            "not_found",         // No exact serial match was found
            "connection_error",  // Can't reach the endpoint
            "auth_required",     // Auth/permission issues
            "rate_limited",      // Rate limiting
            "timeout"            // Request timeout
        };

        return !result.LookupSucceeded 
            && failureStatuses.Contains(result.LookupStatus);
    }

    private static string GetManualLookupButtonText(ImageScrapePreviewResponse result)
    {
        return $"Open {result.DetectedVendor} Support Page";
    }

    private static string ReadableLookupStatus(string status)
    {
        return status switch
        {
            "success" => "Success",
            "blocked" => "Blocked by Vendor",
            "manual_lookup_required" => "Manual Lookup Required",
            "not_found" => "Not Found",
            "not_supported" => "Not Supported",
            "not_attempted" => "Not Attempted",
            "failed_http" => "HTTP Failure",
            "empty" => "Empty Response",
            "connection_error" => "Connection Error",
            "auth_required" => "Authentication Required",
            "rate_limited" => "Rate Limited",
            "timeout" => "Request Timeout",
            "not_enabled" => "Not Enabled",
            "failed_validation" => "Validation Failed",
            _ => string.IsNullOrWhiteSpace(status) ? "Unknown" : status
        };
    }

    private async Task LoadPreferencesAsync()
    {
        try
        {
            var savedPreferences = await JS.InvokeAsync<string?>("hlmTheme.getSavedPreferencesJson");
            if (!string.IsNullOrWhiteSpace(savedPreferences))
            {
                preferences = System.Text.Json.JsonSerializer.Deserialize<UiPreferences>(savedPreferences) ?? new UiPreferences();
            }
        }
        catch
        {
            preferences = new UiPreferences();
        }
    }
}
