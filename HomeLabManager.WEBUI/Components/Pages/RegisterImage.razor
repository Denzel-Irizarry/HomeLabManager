@page "/register-image"
@inject IHttpClientFactory HttpClientFactory
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@rendermode InteractiveServer

<PageTitle>Register By Image</PageTitle>

<div class="container py-4">
    <h1>Register by Image</h1>
    <p class="text-muted">Upload a barcode or QR image to register a device.</p>

    <EditForm Model="formModel" OnSubmit="HandleSubmit">
        <div class="mb-3">
            <InputFile class="form-control" OnChange="HandleFileSelected" accept="image/*" />
        </div>

        @if (selectedFile != null)
        {
            <div class="d-flex align-items-center gap-2 mt-2 mb-3">
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearSelection" title="Remove file">X</button>
                <span>Selected: @selectedFile.Name</span>
            </div>
        }

        <button type="submit" class="btn btn-primary" disabled="@(selectedFile == null || isUploading)">
            @if (isUploading)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span> Uploading...</span>
            }
            else
            {
                <span>Upload Image & Register</span>
            }
        </button>
    </EditForm>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="mt-3">
            <p class="@(isError ? "text-danger" : "text-success") mb-0">@statusMessage</p>
        </div>
    }

    @if (showDevicesLink)
    {
        <div class="mt-2">
            <a class="btn btn-sm btn-outline-secondary" href="/devices">View Devices</a>
        </div>
    }
</div>

@code {
    private class UploadModel { }
    private UploadModel formModel = new();

    private IBrowserFile? selectedFile;
    private bool isUploading;
    private string statusMessage = "";
    private bool isError;
    private bool showDevicesLink;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        statusMessage = "";
        showDevicesLink = false;
        isError = false;
    }

    private void ClearSelection()
    {
        selectedFile = null;
        statusMessage = "";
    }

    private async Task HandleSubmit()
    {
        if (selectedFile == null) return;

        isUploading = true;
        statusMessage = "";

        try
        {
                // starting upload

            using var client = HttpClientFactory.CreateClient("HomeLabApi");
            using var content = new MultipartFormDataContent();

            // Allow larger files, e.g., 20MB max
            long maxFileSize = 10485760 * 2;


            using var sourceStream = selectedFile.OpenReadStream(maxFileSize);



            using var memoryStream = new MemoryStream();

            // Copy in chunks
            var buffer = new byte[81920];
            long total = 0;
            int read;
            while ((read = await sourceStream.ReadAsync(buffer, 0, buffer.Length)) > 0)
            {
                await memoryStream.WriteAsync(buffer, 0, read);
                total += read;
                if (total % 262144 == 0) // every ~256KB
                {
                    // progress
                }
            }

            memoryStream.Position = 0;


            var fileContent = new StreamContent(memoryStream);

            // Protect against empty or invalid content types crashing the headers
            var contentType = string.IsNullOrWhiteSpace(selectedFile.ContentType)
                ? "application/octet-stream"
                : selectedFile.ContentType;

            if (MediaTypeHeaderValue.TryParse(contentType, out var parsedHeader))
            {
                fileContent.Headers.ContentType = parsedHeader;
            }
            else
            {
                fileContent.Headers.ContentType = new MediaTypeHeaderValue("application/octet-stream");
            }

            content.Add(fileContent, "file", selectedFile.Name);

            // sending POST

            using var cts = new CancellationTokenSource(TimeSpan.FromMinutes(2));
            HttpResponseMessage response;
            try
            {
                response = await client.PostAsync("api/devices/register", content, cts.Token);
            }
            catch (OperationCanceledException ex)
            {
                // cancelled/timeout
                throw new Exception("The upload timed out. Please try again with a smaller image or check your connection.", ex);
            }

            var responseText = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Image uploaded and device registered successfully!";
                isError = false;
                showDevicesLink = true;
                selectedFile = null;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                statusMessage = "A device with the same identifier already exists. Please check the image and try again.";
                isError = true;
                showDevicesLink = true;
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                statusMessage = !string.IsNullOrWhiteSpace(responseText) 
                    ? responseText 
                    : "The uploaded image is invalid or unreadable. Please check the image and try again.";
                isError = true;
                showDevicesLink = true;
            }
            else
            {
                statusMessage = $"Failed to register: {(int)response.StatusCode} - {responseText}";
                isError = true;
                showDevicesLink = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"An error occurred while uploading the image: {ex.Message}";
            isError = true;
            showDevicesLink = true;
        }
        finally
        {
            isUploading = false;
        }
    }
}
